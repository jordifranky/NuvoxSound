@model IEnumerable<NuvoxSound.Entities.Producto>
@{
    ViewData["Title"] = "Mi Librería - Nuvox Studio";
    Layout = null;
    var misVentas = ViewBag.MisCompras as List<NuvoxSound.Entities.Venta>;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body>

    <div class="admin-layout">

        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <i class="fa-solid fa-compact-disc text-gold"></i>
                <span class="sidebar-brand-name">NUVOX STUDIO</span>
            </div>

            <div class="nav-label">Mi Cuenta</div>
            <nav class="sidebar-nav">
                <a class="nav-item active" href="javascript:void(0)" id="linkLibreria" onclick="mostrarVistaCliente('viewLibreria', 'linkLibreria')">
                    <span class="nav-icon"><i class="fa-solid fa-headphones"></i></span> Mi Librería
                </a>
                <a class="nav-item" href="javascript:void(0)" id="linkCompras" onclick="mostrarVistaCliente('viewCompras', 'linkCompras')">
                    <span class="nav-icon"><i class="fa-solid fa-file-invoice-dollar"></i></span> Mis Compras
                </a>
                <a class="nav-item" href="javascript:void(0)" id="linkPerfil" onclick="mostrarVistaCliente('viewPerfil', 'linkPerfil')">
                    <span class="nav-icon"><i class="fa-solid fa-user-gear"></i></span> Mi Perfil
                </a>
            </nav>

            <div class="sidebar-footer">
                <a href="/" class="nav-item signout mb-2" style="text-decoration: none;">
                    <span class="nav-icon"><i class="fa-solid fa-store"></i></span> Volver a Tienda
                </a>
                <button class="nav-item signout" onclick="confirmarLogoutCliente(event)" style="width: 100%; border: none; background: transparent; text-align: left; cursor: pointer;">
                    <span class="nav-icon"><i class="fa-solid fa-arrow-right-from-bracket"></i></span> Cerrar Sesión
                </button>
            </div>
        </aside>

        <main class="admin-content">

            <div id="viewLibreria">
                <div class="page-topbar mb-4">
                    <div>
                        <h1 class="page-title text-white">Mi <span style="color: var(--amber);">Librería</span></h1>
                        <p class="page-subtitle">Tus plugins, samples y presets adquiridos listos para descargar</p>
                    </div>
                </div>

                <div class="page-body">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="state-empty shadow-sm" style="background: var(--admin-card); border: 1px dashed var(--admin-border); border-radius: 12px; padding: 80px 20px; text-align: center;">
                            <i class="fa-solid fa-box-open mb-4" style="font-size: 5rem; color: var(--amber); opacity: 0.6;"></i>
                            <h3 style="color: #fff; font-weight: 700; font-family: 'Outfit', sans-serif;">Aún no tienes productos</h3>
                            <p style="color: var(--admin-muted); margin-bottom: 30px; font-size: 1.1rem;">Explora nuestro catálogo premium y empieza a producir como los grandes.</p>
                            <a href="/" class="btn-nuvox-primary text-decoration-none" style="display: inline-flex; align-items: center; gap: 10px; border-radius: 8px; padding: 12px 25px;">
                                <i class="fa-solid fa-store"></i> IR AL CATÁLOGO
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4 justify-content-start">
                            @foreach (var item in Model)
                            {
                                bool sinDescargas = item.DescargasRestantes <= 0;

                                <div class="col">
                                    <div class="card premium-card border-0 h-100 mx-auto" style="background-color: #121212; border-radius: 12px; max-width: 280px; transition: all 0.3s ease;">

                                        <div class="d-flex justify-content-center align-items-center position-relative" style="height: 130px; background: linear-gradient(180deg, #1e1e1e 0%, #111 100%); border-radius: 12px 12px 0 0;">
                                            <span class="position-absolute top-0 start-0 m-2" style="background: rgba(255, 193, 7, 0.1); color: var(--amber); border: 1px solid rgba(255,193,7,0.2); font-size: 0.6rem; font-weight: 700; letter-spacing: 1px; padding: 3px 8px; border-radius: 4px;">
                                                @item.NomCat.ToUpper()
                                            </span>
                                            <i class="@(string.IsNullOrEmpty(item.RutImag) ? "fa-solid fa-compact-disc" : item.RutImag) fa-3x drop-shadow" style="color: #f2f2f2; opacity: 0.9;"></i>
                                        </div>

                                        <div class="card-body p-3 d-flex flex-column">
                                            <h6 class="fw-bold text-white mb-3" style="font-size: 1rem; line-height: 1.3;">@item.NomPro</h6>

                                            <div class="mb-3 flex-grow-1">
                                                <div class="d-flex align-items-center mb-1" style="font-size: 0.75rem; color: #888;">
                                                    <i class="fa-solid fa-check text-success me-2"></i> Uso comercial
                                                </div>
                                                <div class="d-flex align-items-center" style="font-size: 0.75rem; color: #888;">
                                                    <i class="fa-solid fa-check text-success me-2"></i> Studio Standard
                                                </div>
                                            </div>

                                            <div class="mb-3 text-center">
                                                <span class="badge @(sinDescargas ? "bg-danger" : "bg-dark border border-secondary")" style="font-size: 0.7rem; color: @(sinDescargas ? "#fff" : "#aaa");">
                                                    <i class="fa-solid fa-download me-1"></i> @item.DescargasRestantes / 10 Disponibles
                                                </span>
                                            </div>

                                            @if (sinDescargas)
                                            {
                                                <button class="btn w-100 mt-auto fw-bold" disabled style="background-color: #2a2a2a; color: #666; border-radius: 6px; font-size: 0.8rem; padding: 8px 0;">
                                                    LÍMITE ALCANZADO
                                                </button>
                                            }
                                            else
                                            {
                                                <a href="/Cliente/DescargarProducto?id=@item.IdPro" class="btn w-100 mt-auto fw-bold d-flex align-items-center justify-content-center" style="background-color: transparent; color: var(--amber); border: 1px solid var(--amber); border-radius: 6px; padding: 8px 0; font-size: 0.8rem; transition: 0.2s;" onmouseover="this.style.backgroundColor='var(--amber)'; this.style.color='#000';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--amber)';">
                                                    DESCARGAR
                                                </a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div id="viewCompras" style="display: none;">
                <div class="page-topbar mb-4">
                    <div>
                        <h1 class="page-title text-white">Mis Compras</h1>
                        <p class="page-subtitle">Revisa el historial de tus transacciones y boletas</p>
                    </div>
                </div>

                <div class="page-body">
                    @if (misVentas == null || !misVentas.Any())
                    {
                        <div class="state-empty shadow-sm" style="background: var(--admin-card); border: 1px dashed var(--admin-border); border-radius: 12px; padding: 80px 20px; text-align: center;">
                            <i class="fa-solid fa-receipt mb-4" style="font-size: 5rem; color: var(--admin-muted); opacity: 0.3;"></i>
                            <h3 style="color: #fff; font-weight: 700; font-family: 'Outfit', sans-serif;">Sin transacciones</h3>
                            <p style="color: var(--admin-muted); margin-bottom: 0;">No hemos encontrado compras recientes en tu cuenta.</p>
                        </div>
                    }
                    else
                    {
                        <div class="card border-0 shadow-lg" style="background: var(--admin-card); border-radius: 12px; overflow: hidden;">
                            <div class="table-responsive">
                                <table class="table table-hover table-dark align-middle mb-0 text-center" style="--bs-table-bg: transparent;">
                                    <thead style="background: rgba(255,255,255,0.05);">
                                        <tr>
                                            <th class="py-3 text-uppercase text-muted small fw-bold">N° Boleta</th>
                                            <th class="py-3 text-uppercase text-muted small fw-bold">Fecha de Compra</th>
                                            <th class="py-3 text-uppercase text-muted small fw-bold">Estado</th>
                                            <th class="py-3 text-uppercase text-muted small fw-bold">Total</th>
                                            <th class="py-3 text-uppercase text-muted small fw-bold">Acción</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var v in misVentas)
                                        {
                                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                                <td class="py-3 fw-bold" style="color: var(--amber);">#NVX-@v.IdVenta.ToString("D4")</td>
                                                <td class="py-3 text-light">@v.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td class="py-3">
                                                    <span class="badge px-3 py-2 rounded-pill" style="background: rgba(25, 135, 84, 0.2); color: #20c997; border: 1px solid rgba(25, 135, 84, 0.3);">
                                                        <i class="fa-solid fa-circle-check me-1"></i> @v.Estado
                                                    </span>
                                                </td>
                                                <td class="py-3 fw-bold text-white">$@v.Total.ToString("0.00")</td>
                                                <td class="py-3">
                                                    <a href="/Cliente/VerBoleta?idVenta=@v.IdVenta" target="_blank" class="btn btn-sm text-dark fw-bold shadow-sm" style="background-color: var(--amber); border-radius: 6px; padding: 6px 12px; transition: 0.2s;" onmouseover="this.style.opacity='0.8';" onmouseout="this.style.opacity='1';">
                                                        <i class="fa-solid fa-file-pdf me-1"></i> VER BOLETA
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div id="viewPerfil" style="display: none;">
                <div class="page-topbar mb-4">
                    <div>
                        <h1 class="page-title text-white">Mi Perfil</h1>
                        <p class="page-subtitle">Gestiona tu información personal, de productor y preferencias</p>
                    </div>
                </div>

                <div class="page-body">
                    <div class="row">
                        <div class="col-md-10 col-lg-8">
                            <form id="formPerfil" class="shadow-lg p-4 border border-secondary" style="border-radius: 12px; background-color: #121212;">
                                <h4 class="mb-4" style="color: var(--amber);"><i class="fa-solid fa-user-astronaut me-2"></i>Datos de Productor</h4>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Nombres y Apellidos</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-id-card"></i></span>
                                            <input type="text" class="form-control text-white bg-dark border-secondary focus-ring-amber" value="@ViewBag.NombreUsuario">
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Nombre Artístico / Alias</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-headphones"></i></span>
                                            <input type="text" class="form-control text-white bg-dark border-secondary" value="@ViewBag.Alias" placeholder="Ej. SoundArtist">
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Correo Electrónico</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-envelope"></i></span>
                                            <input type="email" class="form-control text-white bg-dark border-secondary" value="@ViewBag.CorreoUsuario" readonly>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Teléfono / WhatsApp</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-phone"></i></span>
                                            <input type="text" class="form-control text-white bg-dark border-secondary" value="@ViewBag.Telefono" placeholder="+51 000 000 000">
                                        </div>
                                    </div>
                                </div>

                                <hr style="border-color: rgba(255,255,255,0.05); margin: 25px 0;">
                                <h4 class="mb-4" style="color: var(--amber);"><i class="fa-solid fa-globe me-2"></i>Preferencias y Localización</h4>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">País de Residencia</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-earth-americas"></i></span>
                                            <select id="selectPais" class="form-select text-white bg-dark border-secondary">
                                                <option value="">Cargando países...</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Moneda de Compra</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-coins"></i></span>
                                            <select class="form-select text-white bg-dark border-secondary">
                                                <option value="USD" selected>Dólar Estadounidense (USD)</option>
                                                <option value="PEN">Sol Peruano (PEN)</option>
                                                <option value="EUR">Euro (EUR)</option>
                                                <option value="MXN">Peso Mexicano (MXN)</option>
                                                <option value="COP">Peso Colombiano (COP)</option>
                                                <option value="ARS">Peso Argentino (ARS)</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-4">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Idioma de Interfaz</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-language"></i></span>
                                            <select class="form-select text-white bg-dark border-secondary">
                                                <option value="es" selected>Español (Latinoamérica)</option>
                                                <option value="en">English (US)</option>
                                                <option value="pt">Português (Brasil)</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Estado de Cuenta</label>
                                        <div class="input-group">
                                            <span class="input-group-text" style="background-color: rgba(25, 135, 84, 0.1); border: 1px solid rgba(25, 135, 84, 0.2); border-right: none; color: #20c997;"><i class="fa-solid fa-shield-check"></i></span>
                                            <input type="text" class="form-control" value="Verificado y Activo" readonly style="background-color: rgba(25, 135, 84, 0.05); color: #20c997; border: 1px solid rgba(25, 135, 84, 0.2); border-left: none; font-weight: bold; cursor: not-allowed;">
                                        </div>
                                    </div>
                                </div>

                                <div class="text-end mt-4">
                                    <button type="submit" class="btn fw-bold px-5 py-2 shadow-sm" style="background-color: var(--amber); color: #000; border-radius: 8px; transition: 0.2s;" onmouseover="this.style.opacity='0.8';" onmouseout="this.style.opacity='1';">
                                        <i class="fa-solid fa-floppy-disk me-2"></i> GUARDAR CAMBIOS
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/cliente-studio.js" asp-append-version="true"></script>
</body>
</html>