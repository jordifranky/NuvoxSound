@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using NuvoxSound.Data
@inject IHttpContextAccessor HttpContextAccessor
@inject ProductoData _productoData
@{
   
    int totalItems = 0;
    var dataSesion = HttpContextAccessor.HttpContext?.Session.GetString("CarritoIDs");
    if (!string.IsNullOrEmpty(dataSesion))
    {
        var diccionario = JsonSerializer.Deserialize<Dictionary<int, int>>(dataSesion);
        if (diccionario != null)
        {
            totalItems = diccionario.Values.Sum();
        }
    }

    
    var objArtistas = _productoData.ObtenerArtistas();
    var jsonArtistas = JsonSerializer.Serialize(objArtistas);
    var listaArtistas = JsonSerializer.Deserialize<List<JsonElement>>(jsonArtistas);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NuvoxSound</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <div class="announcement-bar">
        <div class="marquee-track">
            <span>MASIVE 15+GB TRANCE PRODUCTION TOOLKIT • LIMITED TIME OFFER • 50% OFF</span>
            <span>MASIVE 15+GB TRANCE PRODUCTION TOOLKIT • LIMITED TIME OFFER • 50% OFF</span>
            <span>MASIVE 15+GB TRANCE PRODUCTION TOOLKIT • LIMITED TIME OFFER • 50% OFF</span>
        </div>
    </div>

    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-logo">
                <i class="fa-solid fa-compact-disc logo-icon"></i>
                <span class="logo-text">NUVOX <span class="logo-accent">SOUND</span></span>
            </a>

            <div class="nav-links">

                <div class="nav-item mega-trigger">
                    <a href="#" class="nav-link">CATEGORÍAS <i class="fa-solid fa-caret-down nav-caret"></i></a>
                    <div class="mega-menu">
                        <div class="mega-col">
                            <span class="mega-col-title">Sample Packs</span>
                            <a href="/Tienda/Categoria/Kicks" class="mega-link">Kicks</a>
                            <a href="/Tienda/Categoria/Bateria" class="mega-link">Batería &amp; Percusión</a>
                            <a href="/Tienda/Categoria/Bajos" class="mega-link">Bajos</a>
                            <a href="/Tienda/Categoria/Melodias" class="mega-link">Synths &amp; Melodías</a>
                            <a href="/Tienda/Categoria/Atmósferas" class="mega-link">FX &amp; Atmósferas</a>
                        </div>
                        <div class="mega-col">
                            <span class="mega-col-title">Plug-Ins</span>
                            <a href="/Tienda/Categoria/PluginsEfectos" class="mega-link">Plug-Ins de Efectos</a>
                            <a href="/Tienda/Categoria/RacksAbleton" class="mega-link">Racks de Ableton</a>
                        </div>
                        <div class="mega-col">
                            <span class="mega-col-title">Soundsets</span>
                            <a href="/Tienda/Categoria/Spire" class="mega-link">Spire</a>
                            <a href="/Tienda/Categoria/Serum" class="mega-link">Serum</a>
                            <a href="/Tienda/Categoria/Dune3" class="mega-link">Dune 3</a>
                            <a href="/Tienda/Categoria/Sylenth1" class="mega-link">Sylenth1</a>
                            <a href="/Tienda/Categoria/Gratis" class="mega-link">Gratis</a>
                        </div>
                        <div class="mega-col">
                            <span class="mega-col-title">MIDI Packs</span>
                            <a href="/Tienda/Categoria/MIDIMelodias" class="mega-link">Melodías</a>
                            <a href="/Tienda/Categoria/MIDIAcordes" class="mega-link">Acordes</a>
                            <a href="/Tienda/Categoria/MIDIBass" class="mega-link">Mid Bass</a>
                            <a href="/Tienda/Categoria/MIDIIdeas" class="mega-link">Ideas Completas</a>
                        </div>
                        <div class="mega-col">
                            <span class="mega-col-title">Templates</span>
                            <a href="/Tienda/Categoria/AbletonLive" class="mega-link">Ableton Live</a>
                            <a href="/Tienda/Categoria/FLStudio" class="mega-link">FL Studio</a>
                            <a href="/Tienda/Categoria/StudioOne" class="mega-link">Studio One</a>
                            <a href="/Tienda/Categoria/ConstructionKits" class="mega-link">Construction Kits</a>
                        </div>
                        <div class="mega-col">
                            <span class="mega-col-title">Tutoriales</span>
                            <a href="/Tienda/Categoria/Walkthrough" class="mega-link">Walkthrough Tutorials</a>
                            <a href="/Tienda/Categoria/Blueprint" class="mega-link">Blueprint Tutorials</a>
                            <a href="/Tienda/Categoria/Mezcla" class="mega-link">Tutoriales de Mezcla</a>
                        </div>
                        <div class="mega-col">
                            <span class="mega-col-title">Presets</span>
                            <a href="/Tienda/Categoria/FabfilterQ3" class="mega-link">Fabfilter Pro-Q3</a>
                            <a href="/Tienda/Categoria/FabfilterMB" class="mega-link">Fabfilter Pro-MB</a>
                            <a href="/Tienda/Categoria/Soothe2" class="mega-link">Oeksound Soothe2</a>
                            <a href="/Tienda/Categoria/Ozone" class="mega-link">iZotope Ozone</a>
                        </div>
                    </div>
                </div>

                <div class="nav-item mega-trigger">
                    <a href="#" class="nav-link">ARTISTAS <i class="fa-solid fa-caret-down nav-caret"></i></a>
                    <div class="dropdown dropdown-simple dropdown-artists">
                        @if (listaArtistas != null)
                        {
                            foreach (var artista in listaArtistas)
                            {
                                <a href="/Tienda/Artista/@artista.GetProperty("idArtista").GetInt32()" class="dropdown-link">@artista.GetProperty("nombreArtista").GetString()</a>
                            }
                        }
                    </div>
                </div>

                <div class="nav-item mega-trigger">
                    <a href="#" class="nav-link">SERVICIOS <i class="fa-solid fa-caret-down nav-caret"></i></a>
                    <div class="dropdown dropdown-simple">
                        <a href="/Tienda/Categoria/Mixing" class="dropdown-link">Mezcla &amp; Mastering</a>
                        <a href="/Tienda/Categoria/Signature" class="dropdown-link">Melodías a Medida</a>
                        <a href="/Tienda/Categoria/Tutorias" class="dropdown-link">Tutorías de Producción</a>
                    </div>
                </div>

                <div class="nav-item mega-trigger">
                    <a href="#" class="nav-link">MERCANCÍA <i class="fa-solid fa-caret-down nav-caret"></i></a>
                    <div class="dropdown dropdown-simple">
                        <a href="/Tienda/Categoria/Polos" class="dropdown-link">Polos</a>
                        <a href="/Tienda/Categoria/Buzos" class="dropdown-link">Buzos</a>
                        <a href="/Tienda/Categoria/Hoodies" class="dropdown-link">Hoodies</a>
                        <a href="/Tienda/Categoria/Gorras" class="dropdown-link">Gorras</a>
                    </div>
                </div>

            </div>

            <div class="nav-actions">
                <div class="nav-item" style="margin-right: 10px;">
                    <a href="#" class="nav-link" style="font-weight: 700; color: var(--cream);">
                        <i class="fa-solid fa-globe" style="color: var(--amber);"></i> ES <i class="fa-solid fa-caret-down nav-caret"></i>
                    </a>
                    <div class="dropdown dropdown-simple" style="min-width: 140px; right: 0; left: auto;">
                        <a href="#" class="dropdown-link"><i class="fa-solid fa-check"></i> Español (ES)</a>
                        <a href="#" class="dropdown-link"><i class="fa-solid fa-language" style="color: var(--grey-500);"></i> English (EN)</a>
                    </div>
                </div>

                <div class="currency-toggle" id="currencySelector" style="margin-right: 15px;">
                    <span class="currency-option active" data-curr="USD">USD</span>
                    <span class="currency-divider">/</span>
                    <span class="currency-option" data-curr="PEN">PEN</span>
                </div>

                <button class="nav-btn"><i class="fa-solid fa-magnifying-glass"></i></button>

                @if (User.Identity!.IsAuthenticated)
                {
                    @if (User.IsInRole("1"))
                    {
                        <a asp-controller="Dashboard" asp-action="Index" class="nav-btn" style="color: var(--amber);" title="Panel de Administración">
                            <i class="fa-solid fa-user-shield"></i>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Cliente" asp-action="Index" class="nav-btn" style="color: var(--amber);" title="Mi Librería">
                            <i class="fa-solid fa-circle-user"></i>
                        </a>
                    }
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="nav-btn" title="Iniciar Sesión">
                        <i class="fa-regular fa-user"></i>
                    </a>
                }

                <a href="/Carrito/Index" class="nav-btn cart-btn">
                    <i class="fa-solid fa-bag-shopping"></i>
                    @if (totalItems > 0)
                    {
                        <span class="cart-badge visible">@totalItems</span>
                    }
                </a>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-brand">
                <a href="/" class="nav-logo" style="margin-bottom: 15px; display: inline-flex;">
                    <i class="fa-solid fa-compact-disc logo-icon"></i>
                    <span class="logo-text">NUVOX <span class="logo-accent">SOUND</span></span>
                </a>
                <p class="footer-tagline">
                    Únete a nuestra lista de correos. Sé el primero en enterarte de futuros productos, descuentos y ofertas especiales.
                </p>
                <form class="footer-newsletter" style="display: flex; gap: 8px; margin-bottom: 20px;">
                    <input type="email" placeholder="Tu e-mail..." class="custom-input" style="padding: 10px; font-size: 0.85rem;" required>
                    <button type="submit" class="btn-primary" style="padding: 10px 15px;"><i class="fa-solid fa-envelope"></i></button>
                </form>
                <div class="footer-social">
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-youtube"></i></a>
                    <a href="#"><i class="fa-brands fa-soundcloud"></i></a>
                    <a href="#"><i class="fa-brands fa-spotify"></i></a>
                </div>
            </div>

            <div class="footer-links-group">
                <h4>PRODUCTOS</h4>
                <a href="/Tienda/Categoria/Kicks">Sample Packs</a>
                <a href="/Tienda/Categoria/Spire">Soundsets</a>
                <a href="/Tienda/Categoria/MIDIMelodias">MIDI Packs</a>
                <a href="/Tienda/Categoria/AbletonLive">Templates</a>
                <a href="/Tienda/Categoria/Tutoriales">Tutoriales</a>
            </div>

            <div class="footer-links-group">
                <h4>SOPORTE</h4>
                <a href="/Soporte/Contacto">Contáctanos</a>
                <a href="/Cliente/Index">Mi Cuenta / Descargas</a>
                <a href="/Soporte/FAQ">Preguntas Frecuentes</a>
                <a href="/Soporte/Licencias">Licencias de Uso</a>
            </div>

            <div class="footer-links-group">
                <h4>LEGAL</h4>
                <a href="/Legal/Terminos">Términos de Servicio</a>
                <a href="/Legal/Privacidad">Política de Privacidad</a>
                <a href="/Legal/Reembolsos">Política de Reembolsos</a>
                <a href="/Legal/Retiro">Formulario de Retiro</a>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="copyright">
                &copy; @DateTime.Now.Year Nuvox Records. Todos los derechos reservados.
            </div>
            <div class="footer-currencies">
                <i class="fa-brands fa-cc-visa"></i>
                <i class="fa-brands fa-cc-mastercard"></i>
                <i class="fa-brands fa-cc-paypal"></i>
                <i class="fa-brands fa-apple-pay"></i>
            </div>
        </div>
    </footer>

    <button id="btnAbrirChat" class="chat-trigger-btn" onclick="document.getElementById('nuvoxChatBot').style.display='flex'; this.style.display='none';">
        <i class="fa-solid fa-message"></i>
    </button>

    <div id="nuvoxChatBot" class="chat-container" style="display: none;">
        <div class="chat-header">
            <span><i class="fa-solid fa-robot"></i> Asistente Nuvox</span>
            <span class="chat-close" onclick="document.getElementById('nuvoxChatBot').style.display='none'; document.getElementById('btnAbrirChat').style.display='block';">X</span>
        </div>

        <div id="chatMensajes" class="chat-messages">
            <div class="chat-msg watson-msg">
                <strong>Nuvox Bot:</strong> ¡Hola! Bienvenido a Nuvox Records. ¿En qué te puedo ayudar hoy?
            </div>
        </div>

        <div class="chat-input-area">
            <input type="text" id="chatInput" class="form-control chat-input" placeholder="Escribe tu mensaje..." onkeypress="if(event.key === 'Enter') enviarMensajeChat()">
            <button onclick="enviarMensajeChat()" class="btn chat-send-btn ms-2">
                <i class="fa-solid fa-paper-plane"></i>
            </button>
        </div>

        <div style="padding: 12px; border-top: 1px solid rgba(240, 165, 0, 0.2); text-align: center;">
            <button onclick="if(typeof Tawk_API !== 'undefined') Tawk_API.toggle(); else alert('Cargando chat en vivo...');"
                    style="width: 100%; padding: 10px; background: rgba(240, 165, 0, 0.2); color: #f0a500; border: 1px solid #f0a500; border-radius: 6px; cursor: pointer; font-size: 0.9rem; font-weight: 600; transition: all 0.3s;">
                <i class="fa-solid fa-headset"></i> Hablar con un Asesor en Vivo
            </button>
            <p style="font-size: 0.75rem; color: #606880; margin-top: 8px; margin-bottom: 0;">Conecta con un especialista de Nuvox</p>
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script type="text/javascript">
        var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
        (function(){
        var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
        s1.async=true;
        s1.src='https://embed.tawk.to/YOUR_TAWK_ID/default';
        s1.charset='UTF-8';
        s1.setAttribute('crossorigin','*');
        s0.parentNode.insertBefore(s1,s0);
        })();
    </script>
</body>
</html>