@using System.Text.Json
@model IEnumerable<dynamic>
@{
    ViewData["Title"] = ViewBag.TituloPantalla;

  
    var jsonProductos = JsonSerializer.Serialize(Model);
    var listaProductos = new List<JsonElement>();

    if (!string.IsNullOrEmpty(jsonProductos) && jsonProductos != "null")
    {
        listaProductos = JsonSerializer.Deserialize<List<JsonElement>>(jsonProductos);
    }
}

<div class="section-container" style="padding-top: 60px; padding-bottom: 60px;">

    <div class="section-header" style="text-align: left; margin-bottom: 40px; border-bottom: 1px solid rgba(240, 165, 0, 0.2); padding-bottom: 20px;">
        <span class="section-label">Nuvox Sound Collection</span>
        <h1 class="section-title" style="font-size: 3rem; color: var(--amber);">@ViewBag.TituloPantalla</h1>
        <p class="section-desc">@ViewBag.Subtitulo</p>
    </div>

    <div class="filter-tabs" style="justify-content: flex-start; margin-bottom: 30px;">
        <button class="filter-tab active">Más Populares</button>
        <button class="filter-tab">Recientes</button>
        <button class="filter-tab">Precio: Menor a Mayor</button>
    </div>

    <div class="products-grid">
        @if (listaProductos != null && listaProductos.Count > 0)
        {
            foreach (var prod in listaProductos)
            {
                
                var id = prod.GetProperty("idProducto").GetInt32();
                var nombre = prod.GetProperty("nombre").GetString();
                var artista = prod.GetProperty("artista").GetString();
                var precio = prod.GetProperty("precio").GetDouble();

                
                var coverClass = id % 2 == 0 ? "cover-2" : "cover-1";

                <div class="product-card">
                    <div class="product-img-wrap">
                        <div class="cover-art @coverClass">
                            <div class="cover-waveform mini">
                                <div class="wave-bar"></div><div class="wave-bar"></div>
                                <div class="wave-bar"></div><div class="wave-bar"></div>
                                <div class="wave-bar"></div>
                            </div>
                            <span class="cover-label-mini">VOL @id</span>
                        </div>
                        <div class="product-overlay">
                            <a href="/Tienda/Detalle/@id" class="overlay-btn">Ver Detalles</a>
                            <button class="overlay-btn-ghost" onclick="openQuickView(@id, '@nombre', '@artista', 'Descripción corta', @precio, '@coverClass')">Vista Rápida</button>
                        </div>
                    </div>
                    <div class="product-info">
                        <span class="product-artist">@artista</span>
                        <h3 class="product-name">@nombre</h3>
                        <div class="product-price-wrap">
                            <span class="product-price" data-usd-price="@precio">$@precio.ToString("0.00")</span>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1 / -1; padding: 40px; text-align: center; color: var(--grey-500);">
                <i class="fa-solid fa-compact-disc" style="font-size: 3rem; margin-bottom: 15px; opacity: 0.5;"></i>
                <h4>No hay productos disponibles en esta categoría</h4>
                <p>Estamos trabajando para traer nuevos sonidos pronto.</p>
            </div>
        }
    </div>
</div>