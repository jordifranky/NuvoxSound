@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - NuvoxSound</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="auth-body d-flex align-items-center justify-content-center">

    <!-- Botón flotante para regresar al Home -->
    <a href="/" class="position-absolute top-0 start-0 m-4 text-decoration-none auth-link d-flex align-items-center" style="z-index: 10; font-weight: 600; letter-spacing: 0.05em; font-size: 0.9rem;">
        <i class="fa-solid fa-arrow-left me-2"></i> Volver a la Tienda
    </a>

    <!-- Fondo interactivo -->
    <div class="hero-orb hero-orb-1" style="opacity: 0.6;"></div>
    <div class="hero-orb hero-orb-2" style="opacity: 0.6;"></div>
    <div class="hero-grid"></div>

    <div class="container d-flex justify-content-center">
        <div class="auth-card p-5 w-100" style="max-width: 26rem;">

            <div class="text-center mb-5">
                <div class="auth-logo"><i class="fa-solid fa-compact-disc"></i> NUVOX <span>SOUND</span></div>
                <div class="auth-subtitle">Bienvenido de vuelta</div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-dark-danger rounded" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> @ViewBag.Error
                </div>
            }

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-dark-success rounded" role="alert">
                    <i class="fa-solid fa-circle-check me-2"></i> @ViewBag.Message
                </div>
            }

            <form action="/Auth/Login" method="post">

                <div class="mb-4">
                    <label for="correo" class="auth-form-label">Correo Electrónico</label>
                    <input type="email" class="custom-input" id="correo" name="correo" required placeholder="tu@correo.com" />
                </div>

                <div class="mb-4">
                    <label for="password" class="auth-form-label">Contraseña</label>
                    <input type="password" class="custom-input" id="password" name="password" required placeholder="••••••••" />
                </div>

                <button type="submit" class="btn-primary w-100 py-3 mt-2" style="justify-content: center; font-size: 1rem;">
                    <i class="fa-solid fa-right-to-bracket"></i> INGRESAR
                </button>

            </form>

            <div class="mt-4 text-center" style="font-size: 0.9rem; color: var(--grey-300);">
                ¿No tienes una cuenta?
                <a asp-controller="Auth" asp-action="Registro" class="auth-link text-decoration-none fw-bold ms-1">
                    Regístrate aquí
                </a>
            </div>

        </div>
    </div>

</body>
</html>